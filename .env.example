# Kimi API Key（历史兼容；讲题默认不再使用 Moonshot 官方端点）
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# ─── 同伴评估 / 李老师 / 讲题路由（第十二轮第五轮 · 多模型多样性 + 砍 OCR）──
# 角色 → 模型映射：
#   * 小明 / 班长   → Qwen-VL-Max-latest（ALIYUN_API_KEY）
#   * 大雄          → Kimi-K2.6（KIMI_DASHSCOPE_KEY，model id 必须无前缀的
#                     "kimi-k2.6"；带前缀的 "kimi/kimi-k2.6" 会返回空 choices）
#   * 李老师        → Kimi-K2.6 multimodal（hint + summary）
#   * 兜底          → DeepSeek-V4-Flash 纯文本（任一 multimodal 路径失败时启用）
# 所有 multimodal LLM 直接读 boardImageBase64，并在响应里输出 boardSummary
# （≤30 字）作为白板的精简文字摘要。OCR 主链路已下线。

# 阿里云 DashScope（Qwen-VL multimodal + 兼容 DeepSeek 端点）
# 兼容 OpenAI SDK：https://dashscope.aliyuncs.com/compatible-mode/v1
# 获取地址: https://bailian.console.aliyun.com/
ALIYUN_API_KEY=your_aliyun_dashscope_api_key_here
# 也可只填 DASHSCOPE_API_KEY=...（与 ALIYUN_API_KEY 二选一）
# 实测（scripts/bench_llm_latency.py）：
#   qwen-vl-plus       median 0.67s / p95 2.42s，JSON 合法率 ~67%
#   qwen-vl-max-latest median 1.06s / p95 2.85s，JSON 合法率 100%
# 默认用 max-latest 换稳定性；极速场景可再切 plus，但要接受偶发 JSON 失败。
QWEN_VL_MODEL=qwen-vl-max-latest

# Kimi K2.6 via DashScope（大雄 + 李老师专属，需要先在阿里云控制台开通
# Moonshot K2.6；未开通时返回 BadRequestError: product is not activated）
# 该 key 可与 ALIYUN_API_KEY 复用同一账号，也可单独申请。
KIMI_DASHSCOPE_KEY=your_kimi_dashscope_api_key_here
KIMI_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型 id 必须是 `kimi-k2.6`（**无前缀**）；带前缀的 `kimi/kimi-k2.6` 在
# DashScope 上仍可解析但 vision 实际只走文本路径，会返回空 choices。
KIMI_K2_MODEL=kimi-k2.6

# DeepSeek 讲题 / 通用对话（默认走 DashScope 兼容端点，key 回落 ALIYUN_API_KEY）
# 若仍用官方 DeepSeek 平台，可单独指定 DEEPSEEK_API_KEY + DEEPSEEK_BASE_URL
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# 豆包语音（火山引擎）API Key
# 获取地址: https://www.volcengine.com/docs/6561/1354845
VOLC_API_KEY=your_volc_api_key_here
# 大模型流式 ASR（新版控制台）：VOLC_API_KEY 默认作为 X-Api-Key 使用。
# 2.0 小时版资源 ID：volc.seedasr.sauc.duration
VOLC_ASR_STREAM_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_ASR_STREAM_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
VOLC_ASR_STREAM_API_KEY=
# 旧版控制台兼容字段；新版控制台通常不需要填写。
VOLC_ASR_STREAM_APP_ID=
VOLC_ASR_STREAM_ACCESS_TOKEN=
VOLC_TTS_SPEAKER_XIAOMING=zh_male_wennuanahu_moon_bigtts
VOLC_TTS_SPEAKER_DAXIONG=zh_male_wennuanahu_moon_bigtts
VOLC_TTS_SPEAKER_MONITOR=zh_female_qingchezizi_moon_bigtts
VOLC_TTS_SPEAKER_TEACHER=zh_female_wanwanxiaohe_moon_bigtts

# 商业 OCR / HWR 与知识库检索（白板 HWR 默认走 ALIYUN Qwen-VL；接其他供应商时再填 OCR_HWR_API_KEY）
OCR_HWR_API_KEY=
EMBEDDING_API_KEY=your_embedding_api_key_here
REPLAY_STORAGE_DIR=main/data/replays

# JWT 密钥（生产环境务必修改）
# 不设置时后端启动会随机生成一段 ephemeral key 并打 warning，
# 所有 token 会在重启时失效；生产环境务必设成稳定的 32+ 字节随机串。
JWT_SECRET_KEY=your-jwt-secret-key-here

# 后台系统提示词（可选，不设置则使用默认）
# DEFAULT_SYSTEM_PROMPT=
