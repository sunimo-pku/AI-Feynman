# Kimi API Key
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# DeepSeek API Key（可选，用于切换模型）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 阿里云 DashScope / Qwen-VL（拍照识题 Vision）
# 兼容 OpenAI SDK：默认 base_url 为 https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_API_KEY=your_aliyun_dashscope_api_key_here
QWEN_VL_MODEL=qwen-vl-plus

# 豆包语音（火山引擎）API Key
# 获取地址: https://www.volcengine.com/docs/6561/1354845
VOLC_API_KEY=your_volc_api_key_here
# 大模型流式 ASR（新版控制台）：VOLC_API_KEY 默认作为 X-Api-Key 使用。
# 2.0 小时版资源 ID：volc.seedasr.sauc.duration
VOLC_ASR_STREAM_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_ASR_STREAM_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
VOLC_ASR_STREAM_API_KEY=
# 旧版控制台兼容字段；新版控制台通常不需要填写。
VOLC_ASR_STREAM_APP_ID=
VOLC_ASR_STREAM_ACCESS_TOKEN=
VOLC_TTS_SPEAKER_XIAOMING=zh_male_wennuanahu_moon_bigtts
VOLC_TTS_SPEAKER_DAXIONG=zh_male_wennuanahu_moon_bigtts
VOLC_TTS_SPEAKER_MONITOR=zh_female_qingchezizi_moon_bigtts
VOLC_TTS_SPEAKER_TEACHER=zh_female_wanwanxiaohe_moon_bigtts

# 商业 OCR / HWR 与知识库检索（HWR 默认复用 VOLC_API_KEY；接其他供应商时再单独填）
OCR_HWR_API_KEY=
EMBEDDING_API_KEY=your_embedding_api_key_here
REPLAY_STORAGE_DIR=main/data/replays

# JWT 密钥（生产环境务必修改）
# 不设置时后端启动会随机生成一段 ephemeral key 并打 warning，
# 所有 token 会在重启时失效；生产环境务必设成稳定的 32+ 字节随机串。
JWT_SECRET_KEY=your-jwt-secret-key-here

# 后台系统提示词（可选，不设置则使用默认）
# DEFAULT_SYSTEM_PROMPT=
