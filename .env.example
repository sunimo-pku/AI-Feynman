# Kimi API Key
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# DeepSeek API Key（可选，用于切换模型）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 豆包语音（火山引擎）API Key
# 获取地址: https://www.volcengine.com/docs/6561/1354845
VOLC_API_KEY=your_volc_api_key_here

# JWT 密钥（生产环境务必修改）
# 不设置时后端启动会随机生成一段 ephemeral key 并打 warning，
# 所有 token 会在重启时失效；生产环境务必设成稳定的 32+ 字节随机串。
JWT_SECRET_KEY=your-jwt-secret-key-here

# 后台系统提示词（可选，不设置则使用默认）
# DEFAULT_SYSTEM_PROMPT=
